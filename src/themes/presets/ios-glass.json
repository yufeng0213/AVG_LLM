    "blobPrimary": "rgba(255, 45, 85, 0.15)",
    "blobSecondary": "rgba(90, 200, 250, 0.12)",
    "blobTertiary": "rgba(175, 82, 222, 0.1)",
    "backdropBlur": "20px"
