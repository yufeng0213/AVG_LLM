    "surfacePanel": "rgba(255, 255, 255, 0.1)",
    "surfaceField": "rgba(255, 255, 255, 0.08)",
    "surfaceControl": "rgba(255, 255, 255, 0.15)",
    "surfaceStatus": "rgba(255, 255, 255, 0.12)",
    "borderPanel": "rgba(255, 255, 255, 0.2)",
    "borderField": "rgba(255, 255, 255, 0.15)",
    "borderControl": "rgba(255, 255, 255, 0.25)",
    "borderStatus": "rgba(255, 255, 255, 0.18)",
    "borderAction": "rgba(255, 255, 255, 0.3)",
    "gradientPrimary": "linear-gradient(135deg, rgba(255, 45, 85, 0.6) 0%, rgba(175, 82, 222, 0.5) 100%)",
    "gradientSecondary": "linear-gradient(135deg, rgba(90, 200, 250, 0.5) 0%, rgba(175, 82, 222, 0.4) 100%)",
    "shadowScreen": "0 12px 40px rgba(0, 0, 0, 0.3), 0 4px 12px rgba(0, 0, 0, 0.2)",
