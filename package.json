{
  "name": "avg_llm",
  "productName": "AVG_LLM",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "dev:android": "vite && npx cap run android",
    "start": "electron .",
    "build": "vite build",
    "build:electron": "vite build && electron .",
    "build:android": "vite build && npx cap sync android",
    "build:apk": "vite build && npx cap sync android && cd android && gradlew assembleDebug",
    "build:release": "vite build && npx cap sync android && cd android && gradlew assembleRelease",
    "cap:add": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "preview": "vite preview",
    "ctx": "node scripts/context-router.mjs",
    "ctx:list": "node scripts/context-router.mjs --list",
    "plugins:validate": "node scripts/validate-feature-plugins.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@vladmandic/human": "^3.3.6",
    "electron": "^41.1.1",
    "html2canvas": "^1.4.1",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  }
}
