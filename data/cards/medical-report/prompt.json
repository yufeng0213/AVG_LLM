{
  "id": "medical-report",
  "name": "医疗报告",
  "category": "medical",
  "description": "一份医疗诊断报告，带有专业医疗元素",
  "trigger": {
    "type": "random",
    "probability": 0.02,
    "conditions": [
      {
        "type": "setting",
        "operator": "contains",
        "value": "医院|医疗|诊所|诊断|治疗|医生",
        "description": "医疗场景可能触发"
      }
    ]
  },
  "variables": {
    "reportId": {
      "type": "string",
      "description": "报告编号"
    },
    "patientName": {
      "type": "string",
      "description": "患者姓名"
    },
    "doctor": {
      "type": "string",
      "description": "医生姓名"
    },
    "date": {
      "type": "string",
      "description": "诊断日期"
    },
    "diagnosis": {
      "type": "text",
      "maxLength": 300,
      "description": "诊断内容"
    },
    "treatment": {
      "type": "string",
      "description": "治疗方案"
    },
    "severity": {
      "type": "string",
      "default": "一般",
      "options": ["轻微", "一般", "严重", "紧急"],
      "description": "严重程度"
    }
  },
  "promptTemplate": "请生成一份医疗诊断报告。\n\n背景信息：\n- 患者：{{patientName}}\n- 医生：{{doctor}}\n- 场景：{{scene}}\n\n要求：\n1. 使用专业医疗术语\n2. 内容要客观准确\n3. 包含诊断和建议\n4. 字数控制在150-250字之间\n\n请直接输出报告内容，不要有其他说明。",
  "style": {
    "theme": "medical",
    "colors": ["#f5f5f5", "#2ecc71", "#3498db"],
    "mood": "专业严谨"
  },
  "rarity": "uncommon",
  "collectible": true
}