{
  "id": "terminal-cli",
  "name": "Terminal CLI",
  "description": "终端命令行风格——赛博工业黑客美学。原始命令行力量与等宽字体至上、荧光绿辉光和CRT扫描线深度。真正的复古，极致功能。",
  "styleProfile": "terminal-cli",
  "tokens": {
    "background": "#0C0C0C",
    "foreground": "#33FF00",
    "muted": "#1A1A1A",
    "mutedForeground": "#2D5C2D",
    "accent": "#33FF00",
    "accentLight": "#66FF66",
    "accentDark": "#00CC00",
    "accentForeground": "#0C0C0C",
    "accentMagenta": "#FF00FF",
    "accentCyan": "#00FFFF",
    "accentYellow": "#FFFF00",
    "accentOrange": "#FF8800",
    "accentPurple": "#AA00FF",
    "fontHeading": "'VT323', 'Share Tech Mono', 'IBM Plex Mono', 'Fira Code', monospace",
    "fontBody": "'JetBrains Mono', 'Fira Code', 'IBM Plex Mono', 'Consolas', monospace",
    "fontDisplay": "'VT323', 'Share Tech Mono', 'Press Start 2P', monospace",
    "radiusButton": "0px",
    "radiusCard": "0px",
    "radiusPanel": "0px",
    "textShadowSingle": "0 0 5px rgba(51, 255, 0, 0.6)",
    "textShadowDouble": "0 0 5px rgba(51, 255, 0, 0.6), 0 0 10px rgba(51, 255, 0, 0.4)",
    "textShadowTriple": "0 0 5px rgba(51, 255, 0, 0.6), 0 0 10px rgba(51, 255, 0, 0.4), 0 0 15px rgba(51, 255, 0, 0.2)",
    "surfacePanel": "rgba(26, 60, 26, 0.2)",
    "surfaceField": "#0C0C0C",
    "surfaceControl": "#1A3C1A",
    "surfaceStatus": "rgba(51, 255, 0, 0.08)",
    "borderPanel": "#1A3C1A",
    "borderField": "#1A3C1A",
    "borderControl": "#33FF00",
    "borderStatus": "#FFB000",
    "borderAction": "#33FF00",
    "gradientPrimary": "linear-gradient(180deg, rgba(51, 255, 0, 0.08) 0%, transparent 100%)",
    "gradientSecondary": "linear-gradient(180deg, rgba(255, 176, 0, 0.08) 0%, transparent 100%)",
    "shadowScreen": "none",
    "shadowPanel": "none",
    "shadowCard": "none",
    "shadowField": "none",
    "shadowButton": "0 0 8px rgba(51, 255, 0, 0.4)",
    "shadowButtonDisabled": "none",
    "shadowStatus": "none",
    "shadowPressed": "inset 0 1px 0 rgba(51, 255, 0, 0.2)",
    "blobPrimary": "rgba(51, 255, 0, 0.06)",
    "blobSecondary": "rgba(255, 176, 0, 0.04)",
    "blobTertiary": "rgba(255, 51, 51, 0.02)",
    "backdropBlur": "0px"
  },
  "componentVars": {
    "launchScreenBorder": "1px solid var(--border-panel)",
    "launchScreenRadius": "var(--radius-card)",
    "launchScreenBg": "var(--surface-panel)",
    "launchScreenBackdrop": "none",
    "launchScreenTransform": "none",
    "launchScreenShadow": "var(--shadow-panel)",
    "heroTagBorder": "1px solid var(--border-status)",
    "heroTagRadius": "var(--radius-card)",
    "heroTagBg": "var(--surface-status)",
    "heroTagShadow": "var(--shadow-field)",
    "menuPanelBorder": "1px solid var(--border-panel)",
    "menuPanelBg": "var(--surface-panel)",
    "menuPanelShadow": "var(--shadow-panel)",
    "menuButtonBorder": "1px solid var(--border-control)",
    "menuButtonTransform": "none",
    "menuButtonShadow": "var(--shadow-button)",
    "metaChipBorder": "1px solid var(--border-field)",
    "metaChipRadius": "var(--radius-card)",
    "metaChipBg": "var(--surface-field)"
  }
}
